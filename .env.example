# Database Configuration
POSTGRES_USER=litellm
POSTGRES_PASSWORD=ChangeMe_SecurePassword
POSTGRES_DB=litellm_db

# LiteLLM Master API Key (Must start with sk-)
# Generate a secure key: openssl rand -hex 16
LITELLM_MASTER_KEY=sk-your-secure-master-key-here

# Unique encryption key (Required for storing models/keys safely)
# Generate a secure key: openssl rand -hex 16
LITELLM_SALT_KEY=sk-your-secure-salt-key-here

# External AI Provider Keys (Add whatever you use)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
